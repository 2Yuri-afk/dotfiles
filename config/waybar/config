{
  "layer": "top",
  "position": "top",
  "height": 18,
  "margin-left": 0,
  "margin-right": 0,
  "spacing": 0,
  "margin-bottom": 0,
  "modules-left": [
    "hyprland/workspaces",
    "mpris",
    "custom/screenshot"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "tray",
    "pulseaudio",
    "memory",
    "backlight",
    "network",
    "bluetooth",
    "custom/notification",
    "custom/power"
  ],
  "custom/power": {
    "format": "âڈ»",
